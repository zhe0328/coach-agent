# MySQL
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=coach_agent_db
DB_PORT=3306

# LLM (OpenAI-compatible)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# DeepSeek (optional alternate LLM)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Qdrant (legacy — optional; Chroma is used at runtime)
# QDRANT_API_KEY=
# QDRANT_BASE_URL=

# Embeddings (DashScope / Qwen)
DASHSCOPE_API_KEY=your_dashscope_api_key

# Neo4j
NEO4J_BASE_URL=neo4j+ssc://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Redis (session working memory)
REDIS_URL=redis://localhost:6379/0

# Auth (JWT for chat and protected APIs)
AUTH_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_TOKEN_EXPIRE_HOURS=24

# System
DEBUG=false

# CORS (comma-separated frontend origins)
cors_origins=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
